<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - tp1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/tp1.styles.css" asp-append-version="true" />
    <script src="~/js/CustomScript.js"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <button class="btn btn-outline-primary">

                <img src="~/images/categorie.png" alt="Ouvrir la liste des catégories" id="toggleMenu" />

            </button>
            <div class="container-fluid">
                
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Gestion des articles</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-
                               haspopup="true" aria-expanded="false">Liste d'articles'</a>

                            <div class="dropdown-menu">
                                <a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Create">
                                    Create
                                    article
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index">
                                    List
                                    articles
                                </a>
                            </div>
                        </li>
                    
                    
                        <li>
                   
                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-
                               haspopup="true" aria-expanded="false">Administration</a>

                            <div class="dropdown-menu">
                                <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="CreateRole">
                                    Create
                                    Role
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="ListRoles">
                                    List
                                    Roles
                                </a>
                            </div>
                        </li>
                    }
                    </li>
                    </ul>
                </div>
            </div>
                      
                            @using Microsoft.AspNetCore.Identity
                            @inject SignInManager<IdentityUser> SignInManager
                            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                                <ul class="navbar-nav ml-auto">
                                    @*If the user is signed-in display Logout link*@

                                    @if (SignInManager.IsSignedIn(User))
                                    {
                                        <li class="nav-item">

                                            <form method="post" asp-controller="account" asp-action="logout">
                                                <button type="submit" style="width:auto"
                                                        class="nav-link btn btn-link py-0">

                                                    Logout @User.Identity.Name
                                                </button>
                                            </form>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="nav-item">

                                            <a class="nav-link" asp-controller="Account" asp-action="Register">

                                                Register
                                            </a>
                                        </li>
                                        <li class="nav-item">

                                            <a class="nav-link" asp-controller="Account" asp-action="Login">

                                                Login
                                            </a>
                                        </li>
                                    }
                                </ul>

                       
                    
                
            
            
        </nav>
    </header>
    <div class="container-fluid">
        <div class="row">
            <!-- Menu latéral pour les catégories -->
            <div class="col-md-2" id="sidebar" style="display: none;">
                <p> </p>
                <ul class="list-group">
                    @await Html.PartialAsync("_CategoriesMenu", ViewData["Categories"])

                </ul>
            </div>
            <!-- Contenu principal -->
            <div class="col-md-9" id="mainContent">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>
    

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - tp1 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
